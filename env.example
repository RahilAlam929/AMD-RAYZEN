#
# Root environment example for the AI Social Good app
#

# Server
PORT=5000
NODE_ENV=development
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_NAME=gemini-1.5-flash

# Client (Vite requires VITE_ prefix)
VITE_API_BASE_URL=http://localhost:5000/api

#
# To use this file as a real env file, copy it and rename to `.env`
# in the project root and/or inside `server/` as needed.
#


